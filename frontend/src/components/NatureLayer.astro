---
/**
 * Capa decorativa de "naturaleza animada": hojas, pétalos y mariposas
 * que flotan suavemente sobre el fondo de una sección.
 *
 * Uso: colocar dentro de una sección con `position: relative` y poner el
 * contenido real con `relative z-10` para que quede por encima.
 *
 * Props:
 *  - count:   cantidad de elementos (default 9)
 *  - variant: "leaf" | "petal" | "mixed"  (default "mixed")
 *  - tone:    "primary" | "accent" | "white" | "muted" (color base)
 */
interface Props {
  count?: number;
  variant?: "leaf" | "petal" | "mixed";
  tone?: "primary" | "accent" | "white" | "muted";
}
const { count = 9, variant = "mixed", tone = "primary" } = Astro.props;

const toneClass: Record<string, string> = {
  primary: "text-primary/40",
  accent: "text-accent/35",
  white: "text-white/40",
  muted: "text-secondary/40",
};

// SVGs (currentColor) — hoja, pétalo y mariposa
const shapes = {
  leaf: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M5 21c0-9 7-16 16-16 0 9-7 16-16 16zm2.5-2.2C13 17.2 17.2 13 18.8 7.2 13 8.8 8.8 13 7.5 18.8z"/></svg>`,
  petal: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c3.5 3 5.5 6.5 5.5 10A5.5 5.5 0 0 1 12 17.5 5.5 5.5 0 0 1 6.5 12C6.5 8.5 8.5 5 12 2z"/></svg>`,
  butterfly: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 12c-1.2-3.2-3.4-6-6-6-2 0-3.2 1.6-3.2 3.4 0 2.6 2.4 4.6 5.2 5.1-2.2.4-4.4 1.7-4.4 3.9C3.6 20 4.7 21 6.2 21 9 21 11 17.5 12 14.8 13 17.5 15 21 17.8 21c1.5 0 2.6-1 2.6-2.6 0-2.2-2.2-3.5-4.4-3.9 2.8-.5 5.2-2.5 5.2-5.1C21.2 7.6 20 6 18 6c-2.6 0-4.8 2.8-6 6z"/></svg>`,
};

// Genera propiedades pseudo-aleatorias pero estables en build
const rand = (min: number, max: number, i: number, salt: number) => {
  const x = Math.sin((i + 1) * 12.9898 + salt * 78.233) * 43758.5453;
  const f = x - Math.floor(x);
  return min + f * (max - min);
};

const items = Array.from({ length: count }, (_, i) => {
  let kind: keyof typeof shapes;
  if (variant === "leaf") kind = "leaf";
  else if (variant === "petal") kind = "petal";
  else {
    const r = rand(0, 1, i, 5);
    kind = r < 0.45 ? "leaf" : r < 0.8 ? "petal" : "butterfly";
  }
  const left = rand(2, 94, i, 1);
  const size = rand(14, 34, i, 2);
  const duration = rand(14, 26, i, 3);
  const delay = -rand(0, 22, i, 4);
  const drift = rand(-50, 50, i, 6);
  const opacity = rand(0.28, 0.6, i, 7);
  const fly = kind === "butterfly";
  return { kind, left, size, duration, delay, drift, opacity, fly };
});
---

<div class="nature-layer" aria-hidden="true">
  {items.map((it) => (
    <span
      class:list={["nature-item", { "nature-item--fly": it.fly }, toneClass[tone]]}
      style={`left:${it.left}%;width:${it.size}px;height:${it.size}px;animation-duration:${it.duration}s;animation-delay:${it.delay}s;--drift:${it.drift}px;--leaf-opacity:${it.opacity};`}
      set:html={shapes[it.kind]}
    />
  ))}
</div>
