---
import { Image } from "astro:assets";
import "../styles/global.css";
import logoColor from "../assets/logo-horizontal.png";
import logoWhite from "../assets/logo-horizontal-white.png";
import sealColor from "../assets/logo-stacked.png";
import heroImg from "../assets/hero.jpeg";
import aboutImg from "../assets/about.jpeg";
import donateImg from "../assets/donate.jpeg";

// Gallery photos (optimized at build time by Astro/Sharp)
const galleryModules = import.meta.glob<ImageMetadata>(
  "../assets/gallery/*.jpeg",
  { eager: true, import: "default" }
);
const galleryPics = Object.keys(galleryModules)
  .sort()
  .map((k) => galleryModules[k]);

// ---------------------------------------------------------------------------
// Bilingual dictionary (ES default · EN toggle). Each key = one leaf text node.
// ---------------------------------------------------------------------------
const t = {
  navAbout: { es: "Nosotros", en: "About" },
  navImpact: { es: "Impacto", en: "Impact" },
  navPrograms: { es: "Programas", en: "Programs" },
  navGallery: { es: "Galería", en: "Gallery" },
  navContact: { es: "Contacto", en: "Contact" },
  navDonate: { es: "Donar", en: "Donate" },

  heroKicker: { es: "Siempre hay una esperanza", en: "There is always hope" },
  heroTitle1: { es: "Una mano que", en: "A hand that" },
  heroTitle2: { es: "transforma vidas", en: "transforms lives" },
  heroSubtitle: {
    es: "Formamos con amor y en la Palabra de Dios a 200 niños de la comunidad de Santa Rosa, a las afueras de Cartagena de Indias.",
    en: "With love and the Word of God, we nurture 200 children from the Santa Rosa community, on the outskirts of Cartagena de Indias.",
  },
  heroCta1: { es: "Quiero donar", en: "I want to donate" },
  heroCta2: { es: "Conoce nuestra labor", en: "See our work" },
  heroTrust: { es: "Organización sin ánimo de lucro · NIT 901.325.629", en: "Nonprofit organization · NIT 901.325.629" },

  aboutKicker: { es: "Quiénes somos", en: "Who we are" },
  aboutTitle: { es: "Sembramos esperanza en cada niño", en: "We sow hope in every child" },
  aboutP1: {
    es: "La Fundación Juan Una Mano Ayuda nace para acompañar a los niños y niñas de Santa Rosa, una comunidad a las afueras de Cartagena de Indias. Les llevamos el amor de Dios, formación en valores y momentos que despiertan sonrisas.",
    en: "The Juan Una Mano Ayuda Foundation was born to support the children of Santa Rosa, a community on the outskirts of Cartagena de Indias. We bring them the love of God, an education in values, and moments that spark smiles.",
  },
  aboutP2: {
    es: "Durante el año realizamos jornadas de salud y ortodoncia, entrega de ropa, regalos de Navidad y celebraciones del Día del Niño, porque creemos que cada niño merece crecer sano, amado y con esperanza.",
    en: "Throughout the year we run health and orthodontics days, clothing drives, Christmas gifts and Children's Day celebrations, because we believe every child deserves to grow up healthy, loved and full of hope.",
  },
  verse: {
    es: "«Dejad que los niños vengan a mí.» — Mateo 19:14",
    en: "“Let the little children come to me.” — Matthew 19:14",
  },
  badgeSmiles: { es: "sonrisas", en: "smiles" },
  missionTitle: { es: "Misión", en: "Mission" },
  missionText: {
    es: "Acompañar y formar integralmente a los niños de Santa Rosa, llevándoles el amor de Dios, educación en valores y oportunidades de bienestar mediante jornadas de salud, recreación y entrega de regalos que despiertan sonrisas y sueños.",
    en: "To support and holistically nurture the children of Santa Rosa by bringing them the love of God, an education in values and opportunities for well-being through health days, recreation and gifts that spark smiles and dreams.",
  },
  visionTitle: { es: "Visión", en: "Vision" },
  visionText: {
    es: "Para 2030, ser una fundación referente en el Caribe colombiano en la formación de niños en valores cristianos, ampliando nuestro alcance a nuevas comunidades y garantizando que cada niño crezca sano, amado y con esperanza.",
    en: "By 2030, to be a leading foundation in the Colombian Caribbean for raising children in Christian values, expanding our reach to new communities and ensuring every child grows up healthy, loved and hopeful.",
  },

  impactKicker: { es: "Nuestro impacto", en: "Our impact" },
  impactTitle: { es: "Cifras que son sonrisas", en: "Numbers that are smiles" },
  stat1Label: { es: "Niños atendidos", en: "Children served" },
  stat2Label: { es: "Años de edad", en: "Years old" },
  stat3Label: { es: "Comunidad acompañada", en: "Community served" },
  stat4Label: { es: "Jornadas al año", en: "Outreach events / year" },

  programsKicker: { es: "Qué hacemos", en: "What we do" },
  programsTitle: { es: "Programas que llevan amor", en: "Programs that carry love" },
  programsSubtitle: {
    es: "Cada actividad busca cuidar el cuerpo, el corazón y el espíritu de los niños de Santa Rosa.",
    en: "Every activity is designed to care for the body, heart and spirit of the children of Santa Rosa.",
  },
  p1Title: { es: "Palabra de Dios", en: "Word of God" },
  p1Text: { es: "Encuentros de formación en fe y valores que llevan el amor de Dios al corazón de cada niño.", en: "Faith and values gatherings that bring the love of God to every child's heart." },
  p2Title: { es: "Regalos de Navidad", en: "Christmas Gifts" },
  p2Text: { es: "Cada diciembre llevamos regalos y alegría para que ningún niño se quede sin su Navidad.", en: "Every December we bring gifts and joy so no child is left without a Christmas." },
  p3Title: { es: "Día del Niño", en: "Children's Day" },
  p3Text: { es: "Celebraciones, juegos y regalos para honrar y festejar la niñez de la comunidad.", en: "Celebrations, games and gifts to honor and celebrate the children of the community." },
  p4Title: { es: "Jornadas de Ropa", en: "Clothing Drives" },
  p4Text: { es: "Entrega de ropa y abrigo para los niños y las familias de Santa Rosa.", en: "Clothing and warmth for the children and families of Santa Rosa." },
  p5Title: { es: "Salud y Ortodoncia", en: "Health & Orthodontics" },
  p5Text: { es: "Jornadas de revisión médica y ortodoncia para cuidar la salud de los niños.", en: "Medical check-ups and orthodontics days to care for the children's health." },
  p6Title: { es: "Recreación y Sueños", en: "Play & Dreams" },
  p6Text: { es: "Espacios de juego y aprendizaje que estimulan el desarrollo y los sueños.", en: "Play and learning spaces that nurture development and dreams." },

  galleryKicker: { es: "Galería", en: "Gallery" },
  galleryTitle: { es: "Momentos que lo dicen todo", en: "Moments that say it all" },
  gallerySubtitle: {
    es: "Sonrisas reales de las jornadas con nuestros niños.",
    en: "Real smiles from our days with the children.",
  },

  testKicker: { es: "Testimonios", en: "Testimonials" },
  testTitle: { es: "Voces de esperanza", en: "Voices of hope" },
  t1Quote: { es: "Gracias a la fundación mis hijos reciben amor, atención médica y conocen de Dios. Son una bendición para nuestra comunidad.", en: "Thanks to the foundation my children receive love, medical care and learn about God. They are a blessing for our community." },
  t1Name: { es: "María González", en: "María González" },
  t1Role: { es: "Madre de familia, Santa Rosa", en: "Mother, Santa Rosa" },
  t2Quote: { es: "Ver la sonrisa de los niños en cada jornada es lo que nos mueve. Aquí nadie está solo.", en: "Seeing the children smile at every event is what moves us. Here, no one is alone." },
  t2Name: { es: "Carlos Pérez", en: "Carlos Pérez" },
  t2Role: { es: "Voluntario", en: "Volunteer" },
  t3Quote: { es: "En Navidad recibí mi primer regalo gracias a la fundación. Nunca lo voy a olvidar.", en: "At Christmas I received my first gift thanks to the foundation. I will never forget it." },
  t3Name: { es: "Luisa, 10 años", en: "Luisa, age 10" },
  t3Role: { es: "Niña de la comunidad", en: "Child of the community" },
  testNote: { es: "Testimonios de muestra — se reemplazarán por testimonios reales.", en: "Sample testimonials — to be replaced with real ones." },

  donateKicker: { es: "Dona", en: "Donate" },
  donateTitle: { es: "Tu mano también puede ayudar", en: "Your hand can help too" },
  donateSubtitle: {
    es: "Con tu aporte llevamos salud, educación, regalos y el amor de Dios a los niños de Santa Rosa. Cada peso se transforma en una sonrisa.",
    en: "Your gift brings health, education, presents and the love of God to the children of Santa Rosa. Every peso becomes a smile.",
  },
  amountLabel: { es: "Montos sugeridos", en: "Suggested amounts" },
  donateHowTitle: { es: "Cómo donar", en: "How to donate" },
  bankTitle: { es: "Transferencia Bancolombia", en: "Bancolombia Transfer" },
  bankAccLabel: { es: "Cuenta de ahorros", en: "Savings account" },
  nequiTitle: { es: "Nequi", en: "Nequi" },
  nequiLabel: { es: "Número", en: "Number" },
  copyBtn: { es: "Copiar", en: "Copy" },
  copiedMsg: { es: "¡Copiado!", en: "Copied!" },
  donateNote: {
    es: "Para certificados de donación o donaciones de empresas, escríbenos. ¡Mil gracias por tu generosidad!",
    en: "For donation certificates or corporate giving, write to us. Thank you so much for your generosity!",
  },
  donateTrust: { es: "Fundación Juan Una Mano Ayuda · NIT 901.325.629", en: "Juan Una Mano Ayuda Foundation · NIT 901.325.629" },

  contactKicker: { es: "Contacto", en: "Contact" },
  contactTitle: { es: "Hablemos", en: "Let's talk" },
  contactSubtitle: {
    es: "¿Quieres ser voluntario, aliado o conocer más? Estamos para ayudarte.",
    en: "Want to volunteer, partner with us or learn more? We're here to help.",
  },
  addrLabel: { es: "Dirección", en: "Address" },
  phoneLabel: { es: "Teléfono / WhatsApp", en: "Phone / WhatsApp" },
  emailLabel: { es: "Correo", en: "Email" },
  igLabel: { es: "Instagram", en: "Instagram" },
  waBtn: { es: "Escríbenos por WhatsApp", en: "Message us on WhatsApp" },
  igBtn: { es: "Síguenos en Instagram", en: "Follow us on Instagram" },

  footerBlurb: {
    es: "Llevando amor, salud y la Palabra de Dios a los niños de Santa Rosa, Cartagena de Indias.",
    en: "Bringing love, health and the Word of God to the children of Santa Rosa, Cartagena de Indias.",
  },
  footerLinksTitle: { es: "Navegación", en: "Navigation" },
  footerContactTitle: { es: "Contacto", en: "Contact" },
  footerRights: { es: "Todos los derechos reservados.", en: "All rights reserved." },
  footerMade: { es: "Hecho con amor para los niños de Santa Rosa.", en: "Made with love for the children of Santa Rosa." },
};

// Real data (provided) + placeholders (to confirm)
const INSTAGRAM = "https://www.instagram.com/fjuanunamanoayuda";
const BANK_ACC = "78800001391";
const NEQUI = "3008017056";
const NIT = "901.325.629";
const WHATSAPP = "57XXXXXXXXXX"; // TODO: reemplazar por número real
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Fundación Juan Una Mano Ayuda — Niños de Santa Rosa, Cartagena</title>
    <meta
      name="description"
      content="Fundación Juan Una Mano Ayuda: formamos con amor y en la Palabra de Dios a 200 niños de Santa Rosa, a las afueras de Cartagena de Indias. Dona y transforma vidas."
    />
    <meta name="theme-color" content="#0077C8" />
    <meta property="og:title" content="Fundación Juan Una Mano Ayuda" />
    <meta property="og:description" content="Transformamos la vida de los niños de Santa Rosa, Cartagena de Indias." />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-surface text-ink">
    <!-- Skip link (accessibility) -->
    <a
      href="#contenido"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-primary focus:px-5 focus:py-2 focus:text-white"
      >Saltar al contenido</a
    >

    <!-- ============================= HEADER ============================= -->
    <header id="header" class="site-header fixed inset-x-0 top-0 z-50 py-4">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-5 sm:px-8">
        <a href="#inicio" class="logo-swap block" aria-label="Inicio — Fundación Juan Una Mano Ayuda">
          <Image src={logoWhite} alt="" aria-hidden="true" width={560} height={296} class="logo-white h-11 w-auto sm:h-12" />
          <Image src={logoColor} alt="Logo Fundación Juan Una Mano Ayuda" width={560} height={296} class="logo-color h-11 w-auto sm:h-12" />
        </a>

        <nav class="hidden items-center gap-8 lg:flex" aria-label="Principal">
          <a href="#nosotros" data-header-link class="nav-link text-sm font-medium text-white transition-colors" data-i18n="navAbout">{t.navAbout.es}</a>
          <a href="#impacto" data-header-link class="nav-link text-sm font-medium text-white transition-colors" data-i18n="navImpact">{t.navImpact.es}</a>
          <a href="#programas" data-header-link class="nav-link text-sm font-medium text-white transition-colors" data-i18n="navPrograms">{t.navPrograms.es}</a>
          <a href="#galeria" data-header-link class="nav-link text-sm font-medium text-white transition-colors" data-i18n="navGallery">{t.navGallery.es}</a>
          <a href="#contacto" data-header-link class="nav-link text-sm font-medium text-white transition-colors" data-i18n="navContact">{t.navContact.es}</a>
        </nav>

        <div class="flex items-center gap-2 sm:gap-3">
          <button
            data-lang-toggle
            data-header-link
            class="cursor-pointer rounded-full border border-white px-3 py-1.5 text-xs font-bold font-display text-white transition hover:bg-white/15"
            aria-label="Cambiar idioma / Switch language"
          >EN</button>
          <a
            href="#donar"
            class="btn hidden bg-accent px-5 py-2.5 text-sm text-white shadow-lg shadow-accent/30 hover:bg-accent-dark sm:inline-flex"
            data-i18n="navDonate"
          >{t.navDonate.es}</a>
          <button
            id="menu-btn"
            data-header-link
            class="inline-flex h-11 w-11 cursor-pointer items-center justify-center rounded-full border border-white text-white lg:hidden"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" /></svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden border-t border-black/5 bg-white px-5 pb-6 pt-2 text-ink shadow-xl lg:hidden">
        <nav class="flex flex-col" aria-label="Móvil">
          <a href="#nosotros" class="mobile-link border-b border-black/5 py-3 font-medium" data-i18n="navAbout">{t.navAbout.es}</a>
          <a href="#impacto" class="mobile-link border-b border-black/5 py-3 font-medium" data-i18n="navImpact">{t.navImpact.es}</a>
          <a href="#programas" class="mobile-link border-b border-black/5 py-3 font-medium" data-i18n="navPrograms">{t.navPrograms.es}</a>
          <a href="#galeria" class="mobile-link border-b border-black/5 py-3 font-medium" data-i18n="navGallery">{t.navGallery.es}</a>
          <a href="#contacto" class="mobile-link border-b border-black/5 py-3 font-medium" data-i18n="navContact">{t.navContact.es}</a>
          <a href="#donar" class="mobile-link btn mt-4 bg-accent py-3 text-white" data-i18n="navDonate">{t.navDonate.es}</a>
        </nav>
      </div>
    </header>

    <main id="contenido">
      <!-- ============================= HERO ============================= -->
      <section id="inicio" class="relative flex min-h-[92vh] items-center overflow-hidden">
        <Image
          src={heroImg}
          alt="Niños de la comunidad de Santa Rosa, Cartagena, en una jornada de la fundación"
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
          class="absolute inset-0 h-full w-full object-cover object-center"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-primary-dark/92 via-primary-dark/72 to-primary/45"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-black/15"></div>
        <div class="blob blob--slow pointer-events-none absolute -left-24 top-1/4 h-72 w-72 rounded-full bg-secondary/30 mix-blend-screen"></div>
        <div class="blob blob--delay pointer-events-none absolute -right-16 bottom-10 h-80 w-80 rounded-full bg-accent/20 mix-blend-screen"></div>

        <div class="relative mx-auto w-full max-w-7xl px-5 py-32 sm:px-8">
          <div class="max-w-2xl text-white">
            <p class="reveal font-hand text-3xl text-white sm:text-4xl" data-i18n="heroKicker" style="text-shadow:0 2px 14px rgba(0,0,0,.45)">{t.heroKicker.es}</p>
            <h1 class="reveal mt-3 font-display text-4xl font-extrabold leading-[1.05] sm:text-6xl lg:text-7xl" style="transition-delay:90ms">
              <span data-i18n="heroTitle1">{t.heroTitle1.es}</span><br />
              <span class="text-secondary" data-i18n="heroTitle2">{t.heroTitle2.es}</span>
            </h1>
            <p class="reveal mt-6 max-w-xl text-lg text-white/90 sm:text-xl" data-i18n="heroSubtitle" style="transition-delay:180ms">{t.heroSubtitle.es}</p>
            <div class="reveal mt-9 flex flex-col gap-3 sm:flex-row" style="transition-delay:260ms">
              <a href="#donar" class="btn bg-accent px-8 py-3.5 text-base text-white shadow-xl shadow-accent/40 hover:bg-accent-dark" data-i18n="heroCta1">{t.heroCta1.es}</a>
              <a href="#nosotros" class="btn border-2 border-white/80 px-8 py-3.5 text-base text-white hover:bg-white hover:text-primary-dark" data-i18n="heroCta2">{t.heroCta2.es}</a>
            </div>
            <p class="reveal mt-8 text-sm text-white/75" data-i18n="heroTrust" style="transition-delay:340ms">{t.heroTrust.es}</p>
          </div>
        </div>

        <div class="scroll-hint absolute bottom-7 left-1/2 -translate-x-1/2 text-white/80" aria-hidden="true">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </div>
      </section>

      <!-- ============================= ABOUT ============================= -->
      <section id="nosotros" class="bg-surface py-24 sm:py-32">
        <div class="mx-auto grid max-w-7xl items-center gap-14 px-5 sm:px-8 lg:grid-cols-2 lg:gap-20">
          <div class="reveal relative">
            <div class="absolute -left-5 -top-5 -z-10 h-full w-full rounded-[2.5rem] bg-surface-alt"></div>
            <Image
              src={aboutImg}
              alt="Jornada de la Fundación Juan Una Mano Ayuda con los niños de Santa Rosa"
              widths={[480, 800, 1100]}
              sizes="(max-width:1024px) 100vw, 50vw"
              class="aspect-[4/5] w-full rounded-[2.5rem] object-cover shadow-2xl shadow-primary/15"
            />
            <div class="absolute -bottom-6 -right-4 max-w-[15rem] rounded-2xl bg-white p-5 shadow-xl ring-1 ring-black/5 sm:-right-6">
              <p class="font-hand text-3xl text-accent">+200 <span data-i18n="badgeSmiles">{t.badgeSmiles.es}</span></p>
              <p class="mt-1 text-sm text-muted" data-i18n="stat1Label">{t.stat1Label.es}</p>
            </div>
          </div>

          <div>
            <p class="reveal font-hand text-3xl text-primary" data-i18n="aboutKicker">{t.aboutKicker.es}</p>
            <h2 class="reveal mt-2 text-3xl font-bold sm:text-4xl lg:text-5xl" data-i18n="aboutTitle" style="transition-delay:80ms">{t.aboutTitle.es}</h2>
            <p class="reveal mt-6 text-lg text-muted" data-i18n="aboutP1" style="transition-delay:140ms">{t.aboutP1.es}</p>
            <p class="reveal mt-4 text-lg text-muted" data-i18n="aboutP2" style="transition-delay:200ms">{t.aboutP2.es}</p>

            <div class="reveal mt-8 grid gap-5 sm:grid-cols-2" style="transition-delay:260ms">
              <div class="rounded-2xl border border-black/5 bg-surface-alt p-6">
                <div class="flex h-11 w-11 items-center justify-center rounded-full bg-primary/10 text-primary">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
                </div>
                <h3 class="mt-4 font-bold text-lg" data-i18n="missionTitle">{t.missionTitle.es}</h3>
                <p class="mt-2 text-sm text-muted" data-i18n="missionText">{t.missionText.es}</p>
              </div>
              <div class="rounded-2xl border border-black/5 bg-surface-alt p-6">
                <div class="flex h-11 w-11 items-center justify-center rounded-full bg-accent/10 text-accent">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                </div>
                <h3 class="mt-4 font-bold text-lg" data-i18n="visionTitle">{t.visionTitle.es}</h3>
                <p class="mt-2 text-sm text-muted" data-i18n="visionText">{t.visionText.es}</p>
              </div>
            </div>

            <p class="reveal mt-8 border-l-4 border-primary pl-5 font-hand text-2xl text-ink/80" data-i18n="verse" style="transition-delay:320ms">{t.verse.es}</p>
          </div>
        </div>
      </section>

      <!-- ============================= IMPACT ============================= -->
      <section id="impacto" class="relative overflow-hidden bg-primary py-20 text-white sm:py-24">
        <div class="blob pointer-events-none absolute -right-20 -top-16 h-72 w-72 rounded-full bg-white/10"></div>
        <div class="blob blob--slow pointer-events-none absolute -bottom-24 left-1/4 h-80 w-80 rounded-full bg-primary-dark/40"></div>
        <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
          <div class="mx-auto max-w-2xl text-center">
            <p class="reveal font-hand text-3xl text-white/90" data-i18n="impactKicker">{t.impactKicker.es}</p>
            <h2 class="reveal mt-2 text-3xl font-bold sm:text-4xl" data-i18n="impactTitle" style="transition-delay:80ms">{t.impactTitle.es}</h2>
          </div>
          <dl class="mt-14 grid grid-cols-2 gap-8 text-center lg:grid-cols-4">
            <div class="reveal">
